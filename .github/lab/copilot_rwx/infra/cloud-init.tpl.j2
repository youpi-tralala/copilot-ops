#cloud-config
package_update: true
packages:
  - git
  - curl
  - python3
  - python3-apt
  - python3-pip
  - software-properties-common

runcmd:
  - [ sh, -c, "mkdir -p /opt/copilot_repo && chown -R ${admin_user}:${admin_user} /opt/copilot_repo || true" ]
  - [ sh, -c, "if [ ! -d /opt/copilot_repo/.git ]; then git clone --depth 1 --branch ${git_branch} ${git_repo} /opt/copilot_repo || true; else (cd /opt/copilot_repo && git fetch --all && git reset --hard origin/${git_branch}) fi" ]
  - [ sh, -c, "cd /opt/copilot_repo || exit 0" ]
  - [ sh, -c, "if command -v ansible-playbook >/dev/null 2>&1; then echo 'Ansible present'; else apt-get update && apt-get install -y ansible || pip3 install ansible; fi" ]
  - [ sh, -c, "# Try common bootstrap script locations in the repo; run first that exists (support root lab/ and .github/lab/ layouts)" ]
  - [ sh, -c, "if [ -f ./lab/copilot_rwx/infra/bootstrap.sh ]; then chmod +x ./lab/copilot_rwx/infra/bootstrap.sh && ./lab/copilot_rwx/infra/bootstrap.sh; elif [ -f ./.github/lab/copilot_rwx/infra/bootstrap.sh ]; then chmod +x ./.github/lab/copilot_rwx/infra/bootstrap.sh && ./.github/lab/copilot_rwx/infra/bootstrap.sh; elif [ -f ./lab/copilot_rwx/scripts/bootstrap.sh ]; then chmod +x ./lab/copilot_rwx/scripts/bootstrap.sh && ./lab/copilot_rwx/scripts/bootstrap.sh; elif [ -f ./.github/lab/copilot_rwx/scripts/bootstrap.sh ]; then chmod +x ./.github/lab/copilot_rwx/scripts/bootstrap.sh && ./.github/lab/copilot_rwx/scripts/bootstrap.sh; elif [ -f ./lab/copilot_rwx/playbook.yml ]; then ansible-playbook ./lab/copilot_rwx/playbook.yml -i localhost, -c local || true; elif [ -f ./.github/lab/copilot_rwx/playbook.yml ]; then ansible-playbook ./.github/lab/copilot_rwx/playbook.yml -i localhost, -c local || true; else echo 'No bootstrap script or playbook found in repo: please inspect /opt/copilot_repo'; fi" ]
  - [ sh, -c, "echo 'Bootstrap finished' > /var/log/ollama-bootstrap.log" ]

users:
  - name: ${admin_user}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - "${ssh_public_key}"

final_message: "The system is ready."
